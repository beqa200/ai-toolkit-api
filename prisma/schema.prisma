generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  CANCELLED
}

enum GenerationType {
  IMAGE
  TEXT
}

model GenerationJob {
  id             String         @id @default(cuid())
  originalPrompt String         @map("original_prompt")
  enhancedPrompt String?        @map("enhanced_prompt")
  type           GenerationType
  status         JobStatus      @default(PENDING)
  resultUrl      String?        @map("result_url")
  resultText     String?        @map("result_text")
  errorMessage   String?        @map("error_message")
  priority       Int            @default(0)
  cancelled      Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([priority])
  @@map("generation_jobs")
}
